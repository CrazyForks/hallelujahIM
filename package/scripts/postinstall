#!/bin/bash

login_user=`/usr/bin/stat -f%Su /dev/console`
login_uid=`/usr/bin/id -u "${login_user}"`
USER_HOME=$(eval echo ~${login_user})

# stop any running instance (don't pre-deactivate the freshly-installed bundle)
pkill -9 hallelujah 2>/dev/null || true
sleep 1
pkill -9 hallelujah 2>/dev/null || true

# remove stale per-user copy
rm -rf "${USER_HOME}/Library/Input Methods/hallelujah.app/" 2>/dev/null || true

# copy sqlite database to writable user directory
DB_DIR="${USER_HOME}/Library/Application Support/hallelujah"
mkdir -p "${DB_DIR}"
cp "/Library/Input Methods/hallelujah.app/Contents/Resources/words_with_frequency_and_translation_and_ipa.sqlite3" "${DB_DIR}/"
chown -R "${login_user}" "${DB_DIR}"

# refresh the user's prefs cache BEFORE registering so HIToolbox sees a clean state
launchctl asuser "${login_uid}" sudo -u "${login_user}" killall -HUP cfprefsd 2>/dev/null || true

# register + enable + select inside the user's Aqua launchd session
# (plain `sudo -u` runs outside the user's GUI session and TIS changes don't
# persist correctly there, which leaves the IME in a half-registered state)
launchctl asuser "${login_uid}" sudo -u "${login_user}" \
    "/Library/Input Methods/hallelujah.app/Contents/MacOS/hallelujah" --install

# refresh again so System Settings reflects the new enabled/selected state
launchctl asuser "${login_uid}" sudo -u "${login_user}" killall -HUP cfprefsd 2>/dev/null || true

echo "hallelujah input method registered and activated successfully" > /tmp/hallelujah-postinstall
